# Copier : cp .env.docker.example .env.docker
# Ports Compose → fichier .env séparé (voir docs/DOCKER-PRODUCTION.md)

NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://sdcreativ.com

REDIS_URL=redis://redis:6379

ADMIN_SECRET=
DATABASE_URL=postgresql://sdcreativ:change_me_strong_password@postgres:5432/sdcreativ

# Coordonnées & réseaux sociaux du site public → Paramètres CRM → onglet « Site public »
# (valeurs par défaut si rien n'est enregistré en base)
# NEXT_PUBLIC_CONTACT_PHONE=+225 07 XX XX XX XX
# NEXT_PUBLIC_CONTACT_EMAIL=contact@sdcreativ.com
# NEXT_PUBLIC_CONTACT_ADDRESS=Abidjan, Côte d'Ivoire
# NEXT_PUBLIC_CONTACT_HOURS=Lun – Ven : 8h – 18h
# NEXT_PUBLIC_WHATSAPP_NUMBER=22507XXXXXXXX
# NEXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/sdcreativ
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/company/sdcreativ
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/sdcreativ
# NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/@sdcreativ
# NEXT_PUBLIC_LEGAL_RCCM=
# NEXT_PUBLIC_LEGAL_NCC=
# NEXT_PUBLIC_HOST_NAME=Hostinger International Ltd.
# NEXT_PUBLIC_HOST_ADDRESS=61 Lordou Vironos Street, 6023 Larnaca, Chypre

RESEND_API_KEY=
CONTACT_FROM_EMAIL=contact@sdcreativ.com
CONTACT_FROM_NAME=SD CREATIV
CONTACT_TO_EMAIL=contact@sdcreativ.com

NEXT_PUBLIC_SENTRY_DSN=

CRON_SECRET=
CRON_EMAIL=contact@sdcreativ.com
CRON_MINUTES=45

SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=

AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=sdcreativ-documents-prod
AWS_S3_PUBLIC_BASE_URL=

# Sauvegardes automatiques (prefix S3 + rétention)
AWS_S3_BACKUP_PREFIX=backups/sdcreativ
S3_BACKUP_RETENTION_DAYS=30

CLIENT_PORTAL_TOKENS={}

CRM_BOOTSTRAP_EMAIL=admin@sdcreativ.com
# Mot de passe temporaire au 1er login uniquement — l'admin doit ensuite en choisir un personnel.
REPORT_CRON_RECIPIENTS=direction@sdcreativ.com

