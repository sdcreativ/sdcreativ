# Copier : cp .env.docker.example .env.docker
# Ports Compose → fichier .env séparé (voir docs/DOCKER-PRODUCTION.md)

NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://sdcreativ.com

REDIS_URL=redis://redis:6379

ADMIN_SECRET=
DATABASE_URL=postgresql://sdcreativ:change_me_strong_password@postgres:5432/sdcreativ

# Coordonnées & réseaux sociaux du site public → Paramètres CRM → onglet « Site public »
# (valeurs par défaut si rien n'est enregistré en base)
# NEXT_PUBLIC_CONTACT_PHONE=+225 07 XX XX XX XX
# NEXT_PUBLIC_CONTACT_EMAIL=contact@sdcreativ.com
# NEXT_PUBLIC_CONTACT_ADDRESS=Abidjan, Côte d'Ivoire
# NEXT_PUBLIC_CONTACT_HOURS=Lun – Ven : 8h – 18h
# NEXT_PUBLIC_WHATSAPP_NUMBER=22507XXXXXXXX
# NEXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/sdcreativ
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/company/sdcreativ
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/sdcreativ
# NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/@sdcreativ
# NEXT_PUBLIC_LEGAL_RCCM=
# NEXT_PUBLIC_LEGAL_NCC=
# NEXT_PUBLIC_HOST_NAME=Hostinger International Ltd.
# NEXT_PUBLIC_HOST_ADDRESS=61 Lordou Vironos Street, 6023 Larnaca, Chypre

RESEND_API_KEY=
CONTACT_FROM_EMAIL=contact@sdcreativ.com
CONTACT_FROM_NAME=SD CREATIV
CONTACT_TO_EMAIL=contact@sdcreativ.com

# Anti-bot Cloudflare Turnstile (recommandé en prod — les deux clés requises)
# Créer un widget sur https://dash.cloudflare.com/?to=/:account/turnstile
# Domaines autorisés : sdcreativ.com (+ localhost en dev si besoin)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

NEXT_PUBLIC_SENTRY_DSN=

# Cal.com / Calendly — prise de RDV (page contact + calendrier CRM)
NEXT_PUBLIC_BOOKING_URL=
NEXT_PUBLIC_BOOKING_EMBED_URL=

# Google Analytics 4 — chargé après consentement cookies
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# 3CX Live Chat (NEXT_PUBLIC_* = rebuild Docker obligatoire après changement)
# THREE_CX_PBX_FQDN=1229.3cx.cloud
# NEXT_PUBLIC_THREE_CX_PBX_FQDN=1229.3cx.cloud
# NEXT_PUBLIC_THREE_CX_LIVE_CHAT_LINK=https://1229.3cx.cloud/callus/#sdcreativ
# NEXT_PUBLIC_THREE_CX_ENABLED=true
# NEXT_PUBLIC_THREE_CX_IGNORE_HOURS=true
# THREE_CX_CONFIRMED_AGENTS=1
# THREE_CX_CONSOLE_TESTS_PASSED=false
# THREE_CX_CRM_TOKEN=
# THREE_CX_IP_ALLOWLIST=
# NEXT_PUBLIC_THREE_CX_WEB_CLIENT_URL=https://1229.3cx.cloud
# NEXT_PUBLIC_THREE_CX_RECORDING_NOTICE=false

CRON_SECRET=
CRON_EMAIL=contact@sdcreativ.com
CRON_MINUTES=45

SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=

AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=sdcreativ-documents-prod
AWS_S3_PUBLIC_BASE_URL=

# Sauvegardes automatiques (prefix S3 + rétention)
AWS_S3_BACKUP_PREFIX=backups/sdcreativ
S3_BACKUP_RETENTION_DAYS=30

# Widget santé infra CRM (fichier monté depuis /var/backups/sdcreativ en prod)
# INFRA_STATUS_PATH=/app/data/backups/infra-status.json

CLIENT_PORTAL_TOKENS={}

CRM_BOOTSTRAP_EMAIL=admin@sdcreativ.com
# Domaine imposé pour les invitations équipe CRM (boîtes Hostinger)
# NEXT_PUBLIC_CRM_TEAM_EMAIL_DOMAIN=sdcreativ.com
# Mot de passe temporaire au 1er login uniquement — l'admin doit ensuite en choisir un personnel.
REPORT_CRON_RECIPIENTS=direction@sdcreativ.com

# Messagerie CRM (Hostinger IMAP/SMTP) — voir docs/CRM-MESSAGERIE-PLAN.md
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# MAIL_CREDENTIALS_SECRET=
# MAIL_SYNC_ENABLED=0
# NEXT_PUBLIC_CRM_MESSAGERIE_ENABLED=0
# MAIL_IMAP_HOST=imap.hostinger.com
# MAIL_IMAP_PORT=993
# MAIL_SMTP_HOST=smtp.hostinger.com
# MAIL_SMTP_PORT=465
# Webhook Agentic Mail — Bearer token (hPanel → Agentic mail → Webhooks)
# HOSTINGER_MAIL_WEBHOOK_SECRET=

# PDF server-side (Playwright / Chromium)
# CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Signature électronique tierce (Yousign)
# YOUSIGN_API_KEY=
# YOUSIGN_API_BASE_URL=https://api.yousign.app/v3
# YOUSIGN_WEBHOOK_SECRET=

# --- Fichier .env (Compose, pas ce fichier) ---
# POSTGRES_USER=sdcreativ
# POSTGRES_PASSWORD=change_me_strong_password
# POSTGRES_DB=sdcreativ
# POSTGRES_PORT=5433
# APP_PORT=3001
# DOMAIN=sdcreativ.com
# CERTBOT_EMAIL=admin@sdcreativ.com
# CERTBOT_STAGING=0
