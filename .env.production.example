# =============================================================================
# SD CREATIV — production VPS Hostinger (sdcreativ.com)
# Copier sur le serveur : cp .env.production.example .env.production
# Puis : nano .env.production  (remplir les valeurs marquées OBLIGATOIRE)
# Guide : docs/deploiement-nextjs-vps-hostinger.md
# =============================================================================
# ⚠️ Ne jamais commiter .env.production (secrets). Ce fichier est un modèle.
# ⚠️ Ne pas définir NODE_ENV=development — Next.js utilise production au build/start.

# --- OBLIGATOIRE — Site public (SEO, sitemap, Open Graph, canonical) ---
NEXT_PUBLIC_SITE_URL=https://sdcreativ.com

# --- OBLIGATOIRE — Coordonnées affichées sur le site ---
NEXT_PUBLIC_CONTACT_PHONE=+225 07 XX XX XX XX
NEXT_PUBLIC_CONTACT_EMAIL=contact@sdcreativ.com
NEXT_PUBLIC_CONTACT_ADDRESS=Abidjan, Côte d'Ivoire
NEXT_PUBLIC_CONTACT_HOURS=Lun – Ven : 8h – 18h
NEXT_PUBLIC_WHATSAPP_NUMBER=22507XXXXXXXX

# --- OBLIGATOIRE — Emails formulaires (Resend + domaine vérifié sdcreativ.com) ---
RESEND_API_KEY=
CONTACT_FROM_EMAIL=contact@sdcreativ.com
CONTACT_TO_EMAIL=contact@sdcreativ.com

# --- OBLIGATOIRE — Mentions légales (/mentions-legales) ---
NEXT_PUBLIC_LEGAL_RCCM=
NEXT_PUBLIC_LEGAL_NCC=
NEXT_PUBLIC_HOST_NAME=Hostinger International Ltd.
NEXT_PUBLIC_HOST_ADDRESS=61 Lordou Vironos Street, 6023 Larnaca, Chypre

# --- OBLIGATOIRE si CRM actif (/admin/crm) ---
ADMIN_SECRET=
DATABASE_URL=postgresql://sdcreativ:CHANGER_MOT_DE_PASSE@localhost:5432/sdcreativ

# --- OBLIGATOIRE si rappels calendrier CRM (cron VPS) ---
CRON_SECRET=
CRON_EMAIL=contact@sdcreativ.com
CRON_MINUTES=45

# --- Recommandé — Monitoring & analytics ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_SENTRY_DSN=

# --- Recommandé — Anti-bot formulaires (Cloudflare Turnstile) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Optionnel — Prise de RDV Cal.com ---
NEXT_PUBLIC_BOOKING_URL=
NEXT_PUBLIC_BOOKING_EMBED_URL=

# --- Optionnel — Réseaux sociaux ---
NEXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/sdcreativ
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/company/sdcreativ
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/sdcreativ
NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/@sdcreativ

# --- Optionnel — Avis Google (section accueil si URL renseignée) ---
NEXT_PUBLIC_GOOGLE_REVIEW_URL=

# --- Optionnel — Assistant IA chat ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Optionnel — CMS Sanity ---
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=

# --- Optionnel — Espace client + documents S3 ---
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=sdcreativ-documents-prod
# Format : {"client-slug":{"token":"secret-min-8-chars","name":"…","company":"…"}}
CLIENT_PORTAL_TOKENS={}

# --- Optionnel — CRM avancé ---
CRM_BOOTSTRAP_EMAIL=admin@sdcreativ.com
REPORT_CRON_RECIPIENTS=direction@sdcreativ.com
ICAL_FEED_TOKEN=

# --- Optionnel — Twilio SMS rappels calendrier ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Optionnel — OAuth calendrier Google / Microsoft ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Optionnel — Webhook Cal.com ---
CALCOM_WEBHOOK_SECRET=
