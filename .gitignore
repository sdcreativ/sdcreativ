# See https://help.github.com/articles/ignoring-files/

# --- Dependencies ---
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- User uploads (blog media fallback local) ---
/public/uploads/blog/*
!/public/uploads/blog/.gitkeep

# --- Docker (config Nginx générée par init-letsencrypt.sh) ---
/docker/nginx/conf.d/sdcreativ.conf

# --- Next.js ---
/.next/
/out/
/build

# --- Environment & secrets (VPS : .env sur le serveur, jamais sur Git) ---
.env
.env.docker
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example
!.env.production.example

# --- Vercel (optionnel si déploiement cloud) ---
.vercel

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Logs & debug ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log
pm2-*.log

# --- OS & éditeurs ---
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# --- Sauvegardes locales (PostgreSQL, etc.) ---
/backups/
*.sql.gz
*.dump

# --- Certificats SSL locaux (Let's Encrypt sur VPS = /etc/letsencrypt) ---
*.crt
*.key
!*.key.example

# --- Divers ---
.turbo

# --- Dossiers ---
/docs