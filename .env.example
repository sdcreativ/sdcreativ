# URL publique du site (SEO, sitemap, Open Graph)
# Production VPS : https://sdcreativ.com
NEXT_PUBLIC_SITE_URL=https://sdcreativ.com

# Coordonnées affichées sur le site
NEXT_PUBLIC_CONTACT_PHONE=+225 07 00 00 00 00
NEXT_PUBLIC_CONTACT_EMAIL=contact@sdcreativ.com
NEXT_PUBLIC_CONTACT_ADDRESS=Abidjan, Côte d'Ivoire
NEXT_PUBLIC_CONTACT_HOURS=Lun – Ven : 8h – 18h
NEXT_PUBLIC_WHATSAPP_NUMBER=2250700000000

# Prise de rendez-vous — Cal.com ou Calendly
# Lien direct (bouton) : https://cal.com/votre-compte/30min
NEXT_PUBLIC_BOOKING_URL=
# Embed iframe (optionnel) : https://cal.com/votre-compte/30min?embed=true
NEXT_PUBLIC_BOOKING_EMBED_URL=

# Réseaux sociaux (optionnel)
NEXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/sdcreativ
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/company/sdcreativ
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/sdcreativ
NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/@sdcreativ

# Google Analytics 4 (optionnel — chargé uniquement après consentement cookies)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Assistant IA du site (optionnel — enrichit les réponses au-delà de la base de connaissances)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Lien vers votre fiche Google Business (avis clients — section accueil + schema LocalBusiness)
# Exemple : https://g.page/r/VOTRE_ID/review
NEXT_PUBLIC_GOOGLE_REVIEW_URL=

# CMS Sanity (optionnel — blog & réalisations éditables sans redéploiement)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=

# Monitoring Sentry (optionnel — alertes erreurs en production)
NEXT_PUBLIC_SENTRY_DSN=

# Cloudflare Turnstile — anti-bot formulaires (optionnel ; actif si les deux clés sont renseignées)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Admin interne — CRM Phase 2 (/admin/crm)
ADMIN_SECRET=

# Domaine imposé pour les invitations équipe CRM (boîtes Hostinger) — défaut sdcreativ.com
# NEXT_PUBLIC_CRM_TEAM_EMAIL_DOMAIN=sdcreativ.com

# PostgreSQL — CRM leads
DATABASE_URL=postgresql://user:postgres@localhost:5432/sdcreativ

# AWS S3 — documents espace client (factures, contrats, livrables)
# Voir docs/AWS-DOCUMENTS.md pour la création du bucket et la policy IAM
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=sdcreativ-documents-prod
# Espace client — accès + profils (JSON)
# Format simple : {"client-id":"token-secret-min-8-chars"}
# Format enrichi : {"client-id":{"token":"…","name":"…","company":"…","projectType":"…"}}
CLIENT_PORTAL_TOKENS={}

# Envoi d'emails via Resend (contact, devis, newsletter, rappels calendrier CRM)
RESEND_API_KEY=
CONTACT_FROM_EMAIL=contact@sdcreativ.com
CONTACT_TO_EMAIL=contact@sdcreativ.com

# Mentions légales (affichées sur /mentions-legales)
NEXT_PUBLIC_LEGAL_RCCM=
NEXT_PUBLIC_LEGAL_NCC=
NEXT_PUBLIC_HOST_NAME=Hostinger International Ltd.
NEXT_PUBLIC_HOST_ADDRESS=61 Lordou Vironos Street, 6023 Larnaca, Chypre

# Cron VPS — rappels calendrier email + SMS (GET /api/cron/calendar-reminders)
# Exemple crontab : */5 * * * * curl -s -H "Authorization: Bearer VOTRE_SECRET" https://sdcreativ.com/api/cron/calendar-reminders
# Messagerie IMAP : préférer scripts/install-mail-sync-cron.sh (GET /api/cron/mail-sync)
CRON_SECRET=

# Twilio — rappels SMS calendrier CRM
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OAuth calendrier — sync bidirectionnelle Google / Microsoft
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Webhook Cal.com entrant (POST /api/webhooks/calcom)
CALCOM_WEBHOOK_SECRET=

# CinetPay — paiement en ligne factures (carte + Mobile Money CI)
# Webhook notify : https://votre-domaine.com/api/webhooks/cinetpay
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# Messagerie CRM (Hostinger IMAP/SMTP) — Phase 0+
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# MAIL_CREDENTIALS_SECRET=
# MAIL_SYNC_ENABLED=0
# NEXT_PUBLIC_CRM_MESSAGERIE_ENABLED=0
# MAIL_IMAP_HOST=imap.hostinger.com
# MAIL_IMAP_PORT=993
# MAIL_SMTP_HOST=smtp.hostinger.com
# MAIL_SMTP_PORT=465
# Webhook Agentic Mail (temps réel) — Bearer token hPanel → HOSTINGER_MAIL_WEBHOOK_SECRET
# HOSTINGER_MAIL_WEBHOOK_SECRET=

# Feed iCal calendrier CRM (sinon réutilise CRON_SECRET)
ICAL_FEED_TOKEN=
