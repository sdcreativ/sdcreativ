{
  "name": "sdcreativ",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "playwright test e2e/a11y.spec.ts",
    "playwright:install": "playwright install --with-deps chromium",
    "db:init": "psql \"$DATABASE_URL\" -f scripts/db-init.sql",
    "db:seed-portal": "export DATABASE_URL=\"$(node -e \"const fs=require('fs');const m=fs.readFileSync('.env.local','utf8').match(/^DATABASE_URL=(.+)$/m);if(!m)process.exit(1);console.log(m[1].trim().replace(/^['\\\"]|['\\\"]$/g,''))\")\" && psql \"$DATABASE_URL\" -f scripts/seed-portal-demo.sql",
    "db:purge-portal-demo": "export DATABASE_URL=\"$(node -e \"const fs=require('fs');const m=fs.readFileSync('.env.local','utf8').match(/^DATABASE_URL=(.+)$/m);if(!m)process.exit(1);console.log(m[1].trim().replace(/^['\\\"]|['\\\"]$/g,''))\")\" && psql \"$DATABASE_URL\" -f scripts/purge-portal-demo.sql",
    "db:migrate": "bash scripts/migrate-screativ-to-sdcreativ.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1077.0",
    "@aws-sdk/s3-request-presigner": "^3.1077.0",
    "@sanity/client": "^7.23.0",
    "@sentry/nextjs": "^10.62.0",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "playwright-core": "^1.61.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "sharp": "^0.35.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
